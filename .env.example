# ─────────────────────────────────────────────
# Shots Alarm - .env
# Copy to /home/pi/Shots-Alarm/.env and fill in values
# Then: chmod 600 /home/pi/Shots-Alarm/.env
# ─────────────────────────────────────────────

# Required — MQTT credentials
MQTT_USER=mqttuser
MQTT_PASS=yourpassword

# Optional — override defaults
MQTT_BROKER=homeassistant.local
MQTT_PORT=1883
MQTT_TOPIC=home/shots-alarm/trigger
DEVICE_NAME=shots-alarm

# Optional — behaviour tuning
RECONNECT_S=5
