# ─────────────────────────────────────────────
# Wireless Button - .env
# Copy to /home/pi/.env and fill in values
# Then: chmod 600 /home/pi/.env
# ─────────────────────────────────────────────

# Required — MQTT credentials
MQTT_USER=mqttuser
MQTT_PASS=yourpassword

# Optional — override defaults
MQTT_BROKER=homeassistant.local
MQTT_PORT=1883
MQTT_TOPIC=home/shots-alarm-remote/trigger
MQTT_PAYLOAD=PRESS
DEVICE_NAME=shots-alarm-remote

# Optional — behaviour tuning
POWER_HOLD_S=2.0
RECONNECT_S=5
BLINK_HZ=2
